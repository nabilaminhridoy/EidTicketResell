# ==============================
# Eid Ticket Resell
# ==============================

NODE_ENV="production"

# ==============================
# APP
# ==============================
APP_NAME="Eid Ticket Resell"
APP_URL="https://yourdomain.com"

# ==============================
# AUTH
# ==============================
JWT_SECRET="GENERATE_A_STRONG_RANDOM_SECRET"
JWT_EXPIRES_IN="7d"

# ==============================
# DATABASE (Vercel Compatible)
# ==============================
DATABASE_URL="mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@HOST:PORT/YOUR_DB_NAME"

# OPTIONAL (ONLY FOR MIGRATIONS INSIDE RAILWAY)
DIRECT_URL="mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@HOST:PORT/YOUR_DB_NAME"

# ==============================
# REDIS (Upstash recommended)
# ==============================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ==============================
# EMAIL
# ==============================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@your_domain.com"
SMTP_PASS="your_password"
SMTP_FROM="Eid Ticket Resell <noreply@your_domain.com>"

# ==============================
# ERROR TRACKING
# ==============================
NEXT_PUBLIC_SENTRY_DSN=""

# ==============================
# SECURITY
# ==============================
CRON_SECRET="GENERATE_ANOTHER_STRONG_SECRET"

# ==============================
# PAYMENT GATEWAYS
# ==============================
BKASH_APP_KEY=""
BKASH_APP_SECRET=""

SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_SANDBOX="true"

# ==============================
# FRONTEND
# ==============================
CLIENT_URL="https://your_domain.com"
